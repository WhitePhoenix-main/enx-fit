            <div class="widget-list">
                <div class="row">
                    <div class="col-md-12 widget-holder">
                        <div class="widget-bg">
                            <div class="widget-body clearfix">
                                <h5 class="box-title mr-b-0">Jumbotron</h5>
                                <p class="text-muted">A lightweight, flexible component that can optionally extend the entire viewport to showcase key content on your site.</p>
                                <div class="jumbotron">
                                    <h1 class="display-3">Hello, world!</h1>
                                    <p class="lead">This is a simple hero unit, a simple jumbotron-style component for calling extra attention to featured content or information.</p>
                                    <hr class="my-4">
                                    <p>It uses utility classes for typography and spacing to space content out within the larger container.</p>
                                    <p class="lead"><a class="btn btn-primary btn-lg" href="/wiseowl/default/ui-bootstrap#" role="button">Learn more</a>
                                    </p>
                                </div>
                                <p class="text-muted">To make the jumbotron full width, and without rounded corners, place it outside all <code>.container</code>s and instead add a <code>.container</code> within.</p>
                            </div>
                            <!-- /.widget-body -->
                        </div>
                        <!-- /.widget-bg -->
                    </div>
                    <!-- /.widget-holder -->
                    <div class="col-md-12 widget-holder">
                        <div class="widget-bg">
                            <div class="widget-body clearfix">
                                <h5 class="box-title mr-b-0">Page Header</h5>
                                <p class="text-muted">A simple shell for an <code>h1</code> to appropriately space out and segment sections of content on a page. It can utilize the <code>h1</code>'s default <code>small</code> element, as well as most other components (with additional
                                    styles).</p>
                                <div>
                                    <h2>Example page header <small>Subtext for header</small></h2>
                                </div>
                                <hr>
                            </div>
                            <!-- /.widget-body -->
                        </div>
                        <!-- /.widget-bg -->
                    </div>
                    <!-- /.widget-holder -->
                    <div class="col-md-12 widget-holder">
                        <div class="widget-bg">
                            <div class="widget-body clearfix">
                                <h5 class="box-title">Thumbnails</h5>
                                <h6><strong>Default example</strong></h6>
                                <p class="text-muted">By default, Bootstrap's thumbnails are designed to showcase linked images with minimal required markup.</p>
                                <div class="row">
                                    <div class="col-6 col-md-3">
                                        <a href="/wiseowl/default/ui-bootstrap#">
                                            <img class="img-thumbnail" alt="100%x180" data-src="/wiseowl/html/default/holder.js/100%x180" style="width: 100%; display: block" src="data:image/svg+xml;base64,"
                                            data-holder-rendered="true">
                                        </a>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <a href="/wiseowl/default/ui-bootstrap#">
                                            <img class="img-thumbnail" alt="100%x180" data-src="/wiseowl/html/default/holder.js/100%x180" style="width: 100%; display: block" src="data:image/svg+xml;base64,"
                                            data-holder-rendered="true">
                                        </a>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <a href="/wiseowl/default/ui-bootstrap#">
                                            <img class="img-thumbnail" alt="100%x180" data-src="/wiseowl/html/default/holder.js/100%x180" style="width: 100%; display: block" src="data:image/svg+xml;base64,"
                                            data-holder-rendered="true">
                                        </a>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <a href="/wiseowl/default/ui-bootstrap#">
                                            <img class="img-thumbnail" alt="100%x180" data-src="/wiseowl/html/default/holder.js/100%x180" style="width: 100%; display: block" src="data:image/svg+xml;base64,"
                                            data-holder-rendered="true">
                                        </a>
                                    </div>
                                </div>
                                <!-- /.row -->
                                <h6><strong>Custom content</strong></h6>
                                <p class="text-muted">With a bit of extra markup, it's possible to add any kind of HTML content like headings, paragraphs, or buttons into thumbnails.</p>
                                <div class="row">
                                    <div class="col-sm-6 col-md-4">
                                        <div class="img-thumbnail">
                                            <img alt="100%x200" data-src="/wiseowl/html/default/holder.js/100%x200" style="width: 100%; display: block" src="data:image/svg+xml;base64,"
                                            data-holder-rendered="true">
